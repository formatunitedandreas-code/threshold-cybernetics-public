{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Public PR185 case study manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "caseStudyId",
    "historical",
    "nonAuthorizing",
    "authorityCurrentlyActive",
    "repository",
    "pullRequest",
    "baseSha",
    "finalHeadSha",
    "mergeSha",
    "mergeMethod",
    "outcome",
    "failClosedEvents",
    "checks",
    "openBlockingFindings",
    "remainingMergeAuthority",
    "finiteGrantActive",
    "releaseAuthorized",
    "deployAuthorized",
    "redactions",
    "nonClaims",
    "publicLinks"
  ],
  "properties": {
    "schemaVersion": { "const": "threshold.public-case-study.v0.1" },
    "caseStudyId": { "const": "petclinic-pr185" },
    "historical": { "const": true },
    "nonAuthorizing": { "const": true },
    "authorityCurrentlyActive": { "const": false },
    "repository": { "const": "formatunitedandreas-code/spring-framework-petclinic" },
    "pullRequest": { "const": 185 },
    "baseSha": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "finalHeadSha": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "mergeSha": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "mergeMethod": { "const": "squash" },
    "outcome": { "const": "merged_and_reconciled" },
    "failClosedEvents": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "checks": { "type": "array", "items": { "type": "object", "additionalProperties": false, "required": ["name", "conclusion"], "properties": { "name": { "type": "string" }, "conclusion": { "const": "success" } } } },
    "openBlockingFindings": { "const": 0 },
    "remainingMergeAuthority": { "const": 0 },
    "finiteGrantActive": { "const": false },
    "releaseAuthorized": { "const": false },
    "deployAuthorized": { "const": false },
    "redactions": { "type": "array", "items": { "type": "string" } },
    "nonClaims": { "type": "array", "items": { "type": "string" } },
    "publicLinks": { "type": "object", "additionalProperties": { "type": "string", "pattern": "^https://github.com/" } }
  }
}

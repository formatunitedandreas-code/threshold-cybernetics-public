{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Public Pre-Execution Commitment v0.1",
  "type": "object",
  "required": ["schemaVersion", "caseStudyId", "runId", "historical", "nonAuthorizing", "phase", "candidate", "boundBeforeProductExecution", "observedState", "validation", "commitments", "authority", "claims"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": { "const": "threshold.public-pre-execution-commitment.v0.1" },
    "caseStudyId": { "const": "petclinic-senior-refactoring-v0-1" },
    "runId": { "const": "SRR-PETCLINIC-001" },
    "historical": { "const": true },
    "nonAuthorizing": { "const": true },
    "phase": { "const": "pre_execution" },
    "candidate": {
      "type": "object",
      "required": ["candidateId", "score", "leadOverRunnerUp"],
      "additionalProperties": false,
      "properties": {
        "candidateId": { "const": "owner-web-flow-responsibility-split-v0-1" },
        "score": { "const": 34 },
        "leadOverRunnerUp": { "const": 7 }
      }
    },
    "boundBeforeProductExecution": {
      "type": "object",
      "required": ["candidateIdentity", "candidateScope", "architectureBaseline", "behavioralInvariants", "qualityProfile", "threeBatchPlan", "counterfactualPlanReview"],
      "additionalProperties": false,
      "properties": {
        "candidateIdentity": { "const": true },
        "candidateScope": { "const": true },
        "architectureBaseline": { "const": true },
        "behavioralInvariants": { "const": true },
        "qualityProfile": { "const": true },
        "threeBatchPlan": { "const": true },
        "counterfactualPlanReview": { "const": true }
      }
    },
    "observedState": {
      "type": "object",
      "required": ["productSourceChanged", "productTestsChanged", "part2Executed", "pushExecuted", "pullRequestCreated", "mergeExecuted", "redditPostCreated"],
      "additionalProperties": false,
      "properties": {
        "productSourceChanged": { "const": false },
        "productTestsChanged": { "const": false },
        "part2Executed": { "const": false },
        "pushExecuted": { "const": false },
        "pullRequestCreated": { "const": false },
        "mergeExecuted": { "const": false },
        "redditPostCreated": { "const": false }
      }
    },
    "validation": {
      "type": "object",
      "required": ["thresholdContractsTestsPassed", "refactoringGovernorTestsPassed", "petClinicCandidateDiscoveryTest", "petClinicPlanTest"],
      "additionalProperties": false,
      "properties": {
        "thresholdContractsTestsPassed": { "type": "integer", "const": 110 },
        "refactoringGovernorTestsPassed": { "type": "integer", "const": 405 },
        "petClinicCandidateDiscoveryTest": { "const": "passed" },
        "petClinicPlanTest": { "const": "passed" }
      }
    },
    "authority": {
      "type": "object",
      "required": ["executionAuthorized", "publicationAuthorized", "mergeAuthorized", "releaseAuthorized"],
      "additionalProperties": false,
      "properties": {
        "executionAuthorized": { "const": false },
        "publicationAuthorized": { "const": false },
        "mergeAuthorized": { "const": false },
        "releaseAuthorized": { "const": false }
      }
    },
    "claims": {
      "type": "object",
      "required": ["refactoringExecuted", "qualityAssessmentPassed", "architectureImproved", "humanSeniorEquivalent", "formalVerificationClaim", "independentObserver"],
      "additionalProperties": false,
      "properties": {
        "refactoringExecuted": { "const": false },
        "qualityAssessmentPassed": { "const": false },
        "architectureImproved": { "const": false },
        "humanSeniorEquivalent": { "const": false },
        "formalVerificationClaim": { "const": false },
        "independentObserver": { "const": false }
      }
    },
    "commitments": {
      "type": "object",
      "required": ["part1HandoffDigest", "executionDecisionPacketDigest"],
      "additionalProperties": false,
      "properties": {
        "part1HandoffDigest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
        "executionDecisionPacketDigest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" }
      }
    }
  }
}

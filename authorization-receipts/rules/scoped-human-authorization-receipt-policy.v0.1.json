{
  "policy_set_id": "scoped_human_authorization_receipt_validation_v0_1",
  "policy_mode": "non_authorizing_receipt_scope_validation",
  "non_claims": [
    "Receipt Validation is not patch execution",
    "Receipt Validation is not PR creation",
    "Receipt Validation is not merge approval",
    "Receipt Validation is not deployment readiness",
    "Receipt Valid is not action allowed",
    "Receipt Scope Match is not runtime authority"
  ],
  "scope_validation_rules": {
    "readout_only": {
      "required_scope": "none",
      "receipt_required": false,
      "action_allowed": false
    },
    "standard_human_review_required": {
      "required_scope": "human_review_candidate_scope",
      "receipt_required": true,
      "action_allowed": false
    },
    "strict_human_review_required": {
      "required_scope": "strict_human_review_candidate_scope",
      "receipt_required": true,
      "action_allowed": false
    },
    "hold_for_manual_triage": {
      "required_scope": "manual_triage_scope",
      "receipt_required": true,
      "action_allowed": false
    }
  }
}
